{
  "outputDirectory": "htdocs",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/hakkimda",   "destination": "/about.html"    },
    { "source": "/projeler",   "destination": "/project.html"  },
    { "source": "/servisler",  "destination": "/services.html" },
    { "source": "/aktiviteler","destination": "/fav.html"      }
  ],
  "redirects": [
    { "source": "/index.html",    "destination": "/",             "permanent": true },
    { "source": "/about.html",    "destination": "/hakkimda",     "permanent": true },
    { "source": "/about",         "destination": "/hakkimda",     "permanent": true },
    { "source": "/project.html",  "destination": "/projeler",     "permanent": true },
    { "source": "/project",       "destination": "/projeler",     "permanent": true },
    { "source": "/services.html", "destination": "/servisler",    "permanent": true },
    { "source": "/services",      "destination": "/servisler",    "permanent": true },
    { "source": "/fav.html",      "destination": "/aktiviteler",  "permanent": true },
    { "source": "/fav",           "destination": "/aktiviteler",  "permanent": true }
  ],
  "functions": {
    "htdocs/api/**/*.js": {
      "memory": 128,
      "maxDuration": 10
    }
  }
}
