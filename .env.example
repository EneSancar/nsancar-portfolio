# Vercel → Project → Settings → Environment Variables
# Production, Preview ve Development için ekle
GOOGLE_DRIVE_API_KEY=buraya_yeni_anahtar

# Google Cloud Console:
# 1. "Google Drive API" etkin olsun
# 2. API key → Application restrictions: None (sunucu tarafı)
# 3. API key → API restrictions: sadece Google Drive API
# 4. Drive klasörü: "Bağlantıya sahip olan herkes" görüntüleyebilir
